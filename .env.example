# Standard Postgres connection string (postgres://user:pass@host:port/db).
# Production: Neon connection string. Local dev: run `npx prisma dev` and use the
# raw TCP url it prints (NOT the prisma+postgres:// proxy url — the pg driver adapter needs raw postgres://).
DATABASE_URL=""

# NextAuth v5 session secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# AssemblyAI API key (https://www.assemblyai.com/) — used for transcription + diarization
ASSEMBLYAI_API_KEY=""

# Vercel Blob read/write token (https://vercel.com/docs/storage/vercel-blob) — used for video/audio storage
BLOB_READ_WRITE_TOKEN=""

# Public base URL AssemblyAI's webhook calls back to. localhost only works with a tunnel (e.g. ngrok).
APP_URL=""

# Optional: protects /api/cron/process-jobs from public invocation. Vercel sets this automatically in production.
CRON_SECRET=""
