# Standard Postgres connection string (postgres://user:pass@host:port/db).
# Production: Neon connection string. Local dev: run `npx prisma dev` and use the
# raw TCP url it prints (NOT the prisma+postgres:// proxy url — the pg driver adapter needs raw postgres://).
DATABASE_URL=""

# NextAuth v5 session secret — generate with: openssl rand -base64 32
AUTH_SECRET=""

# AssemblyAI API key (https://www.assemblyai.com/) — used for transcription + diarization
ASSEMBLYAI_API_KEY=""

# Anthropic API key (https://console.anthropic.com/) — used to generate hearing summaries
ANTHROPIC_API_KEY=""

# Vercel Blob read/write token (https://vercel.com/docs/storage/vercel-blob) — used for video/audio storage
BLOB_READ_WRITE_TOKEN=""

# Public base URL AssemblyAI's webhook calls back to. localhost only works with a tunnel (e.g. ngrok).
APP_URL=""

# Optional: protects /api/cron/process-jobs from public invocation. Vercel sets this automatically in production.
CRON_SECRET=""

# Resend API key (https://resend.com/) — used to send password reset emails
RESEND_API_KEY=""

# From address for transactional emails, e.g. "LexScript <no-reply@yourdomain.com>"
EMAIL_FROM=""

# Sentry DSN for server/edge error reporting (https://sentry.io/)
SENTRY_DSN=""

# Sentry DSN for browser error reporting — same project, public-safe
NEXT_PUBLIC_SENTRY_DSN=""

# Sentry auth token — used both for build source-map upload and the admin observability
# issues feed (org settings > Auth Tokens; needs project:read scope for the feed)
SENTRY_AUTH_TOKEN=""

# Sentry org and project slugs — used by the admin observability page to fetch recent issues
SENTRY_ORG=""
SENTRY_PROJECT=""

# Upstash Redis REST credentials (https://upstash.com/) — used for rate limiting
# (login, signup, forgot-password, video upload/create). Without these, rate
# limiting fails open (no-op) and nothing breaks.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
