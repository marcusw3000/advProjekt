// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String
  name           String?
  minutesBalance Int      @default(30)
  isAdmin        Boolean  @default(false)
  createdAt      DateTime @default(now())

  videos              Video[]
  folders             Folder[]
  minutesTransactions MinutesTransaction[]
  passwordResetTokens PasswordResetToken[]
  supportTickets      SupportTicket[]
  sharesGiven         VideoShare[]         @relation("SharedByUser")
  sharesReceived      VideoShare[]         @relation("SharedWithUser")
}

enum MinutesReason {
  SIGNUP_GRANT
  VIDEO_TRANSCRIPTION
  PURCHASE
  ADMIN_ADJUSTMENT
}

model MinutesTransaction {
  id          String        @id @default(cuid())
  userId      String
  amount      Int
  reason      MinutesReason
  videoId     String?
  amountCents Int?
  currency    String?       @default("BRL")
  createdAt   DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CronRun {
  id          String    @id @default(cuid())
  startedAt   DateTime  @default(now())
  finishedAt  DateTime?
  reconciled  Int       @default(0)
  processed   Int       @default(0)
  timedOut    Int       @default(0)
  error       String?

  @@index([startedAt])
}

enum VideoSourceType {
  UPLOAD
  URL
}

enum JobStatus {
  PENDING
  DOWNLOADING
  PROCESSING
  COMPLETE
  FAILED
}

model Video {
  id                 String          @id @default(cuid())
  userId             String
  folderId           String?
  title              String
  sourceType         VideoSourceType
  sourceUrl          String?
  storageKey         String?
  storageProvider    String          @default("r2")
  storageBucket      String?
  mimeType           String?
  fileSizeBytes      BigInt?
  uploadedAt         DateTime?
  deletedAt          DateTime?
  durationSeconds    Int?
  status             JobStatus       @default(PENDING)
  createdAt          DateTime        @default(now())
  summary            String?         @db.Text
  summaryStatus      JobStatus?
  summaryError       String?
  summaryGeneratedAt DateTime?

  user     User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder   Folder?            @relation(fields: [folderId], references: [id], onDelete: SetNull)
  job      TranscriptionJob?
  segments TranscriptSegment[]
  shares   VideoShare[]

  @@index([userId])
  @@index([folderId])
}

model VideoShare {
  id               String   @id @default(cuid())
  videoId          String
  sharedByUserId   String
  sharedWithUserId String
  createdAt        DateTime @default(now())

  video      Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
  sharedBy   User  @relation("SharedByUser", fields: [sharedByUserId], references: [id], onDelete: Cascade)
  sharedWith User  @relation("SharedWithUser", fields: [sharedWithUserId], references: [id], onDelete: Cascade)

  @@unique([videoId, sharedWithUserId])
  @@index([sharedWithUserId])
  @@index([videoId])
}

model Folder {
  id        String   @id @default(cuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  videos Video[]

  @@index([userId])
}

model TranscriptionJob {
  id           String    @id @default(cuid())
  videoId      String    @unique
  status       JobStatus @default(PENDING)
  asrProvider  String    @default("assemblyai")
  asrJobId     String?
  errorMessage String?
  attemptCount Int       @default(0)
  nextRetryAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)
}

enum SupportTicketStatus {
  OPEN
  CLOSED
}

model SupportTicket {
  id        String              @id @default(cuid())
  userId    String
  subject   String
  message   String              @db.Text
  status    SupportTicketStatus @default(OPEN)
  createdAt DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TranscriptSegment {
  id                   String   @id @default(cuid())
  videoId              String
  speakerLabel         String
  originalSpeakerLabel String
  startMs              Int
  endMs                Int
  text                 String
  order                Int
  createdAt            DateTime @default(now())

  video Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  @@index([videoId, order])
}
